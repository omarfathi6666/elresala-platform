generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ExamAvailabilityMode {
  IMMEDIATELY
  AFTER_LECTURE_COMPLETION
  SPECIFIC_DATE
  HIDDEN
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id          String       @id @default(cuid())
  name        String
  phone       String       @unique
  parentPhone String?
  email       String?      @unique
  password    String
  governorate String
  grade       String
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  codes       Code[]
  results     ExamResult[]
}

model Course {
  id          String    @id @default(cuid())
  title       String
  description String?
  order       Int
  createdAt   DateTime  @default(now())
  chapters    Chapter[]
  codes       Code[]
}

model Chapter {
  id        String    @id @default(cuid())
  title     String
  order     Int
  courseId  String
  createdAt DateTime  @default(now())
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lectures  Lecture[]
  codes     Code[]
}

model Lecture {
  id          String   @id @default(cuid())
  title       String
  description String?
  videoUrl    String?
  pdfUrl      String?
  duration    Int?
  order       Int
  isPublished Boolean  @default(false)
  chapterId   String
  createdAt   DateTime @default(now())
  exams       Exam[]
  chapter     Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  codes       Code[]
}

model Exam {
  id               String               @id @default(cuid())
  title            String
  duration         Int
  totalMarks       Int
  isPublished      Boolean              @default(false)
  availabilityMode ExamAvailabilityMode @default(IMMEDIATELY)
  availableFrom    DateTime?
  lectureId        String
  createdAt        DateTime             @default(now())
  lecture          Lecture              @relation(fields: [lectureId], references: [id], onDelete: Cascade)
  results          ExamResult[]
  questions        Question[]
}

model Question {
  id            String   @id @default(cuid())
  question      String
  choiceA       String
  choiceB       String
  choiceC       String
  choiceD       String
  correctAnswer String
  explanation   String?
  image         String?
  order         Int
  examId        String
  createdAt     DateTime @default(now())
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  submittedAnswers ExamResultAnswer[]
}

model Code {
  id          String    @id @default(cuid())

  code        String    @unique

  courseId    String
  course      Course    @relation(fields: [courseId], references: [id])

  chapterId   String?
  chapter     Chapter?  @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  lectureId   String?
  lecture     Lecture?  @relation(fields: [lectureId], references: [id], onDelete: SetNull)

  studentId   String?
  student     Student?  @relation(fields: [studentId], references: [id])

  isUsed      Boolean   @default(false)

  usedCount   Int       @default(0)

  maxDevices  Int       @default(1)

  expiresAt   DateTime?

  createdAt   DateTime  @default(now())

  usedAt      DateTime?
}

model ExamResult {
  id          String   @id @default(cuid())
  score       Int
  total       Int
  startedAt   DateTime
  submittedAt DateTime
  studentId   String
  examId      String
  createdAt   DateTime @default(now())
  exam        Exam     @relation(fields: [examId], references: [id])
  answers     ExamResultAnswer[]
  student     Student  @relation(fields: [studentId], references: [id])
}

model ExamResultAnswer {
  id            String     @id @default(cuid())
  resultId      String
  questionId    String
  studentAnswer String
  correctAnswer String
  isCorrect     Boolean
  createdAt     DateTime   @default(now())
  question      Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  result        ExamResult @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@index([resultId])
  @@index([questionId])
}
